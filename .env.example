# PostgreSQL 数据库连接地址，供 SQLAlchemy 创建数据库引擎使用
DATABASE_URL=postgresql://user:password@localhost:5432/scaffold_db

# JWT 签名密钥，供用户登录令牌签发与校验使用
SECRET_KEY=your-secret-key-here

# 访问令牌有效期，单位为分钟；10080 表示 7 天
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# 当前运行环境标识，如 development / production
ENVIRONMENT=development

# 允许跨域访问的前端来源地址
ALLOWED_ORIGINS=http://localhost:5173
# 生产环境改为你的域名，多个域名用逗号分隔
# 例如：https://www.yourdomain.com,https://yourdomain.com
